{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Unipay",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "appearance": {
    "default": "dark"
  },
  "css": ["styles.css"],
  "theme": "mint",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "quickstart",
              "how-it-works"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/send",
              "features/swap",
              "features/payroll",
              "features/privacy"
            ]
          },
          {
            "group": "About",
            "pages": [
              "about/team",
              "about/security"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              "legal/terms",
              "legal/conditions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/errors"
            ]
          },
          {
            "group": "Quotes",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/quotes/refresh"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "api-reference/endpoint/create",
              "api-reference/transactions/status",
              "api-reference/endpoint/delete",
              "api-reference/transactions/history"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/endpoint/webhook",
              "api-reference/webhooks/list",
              "api-reference/webhooks/update",
              "api-reference/webhooks/delete"
            ]
          },
          {
            "group": "Balances",
            "pages": [
              "api-reference/balances/get",
              "api-reference/balances/tokens"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://unipayfi.pro"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/unipayy/solana-privacy-layer"
        },
        {
          "anchor": "Twitter",
          "icon": "twitter",
          "href": "https://x.com/UniPaymentss"
        },
        {
          "anchor": "Telegram",
          "icon": "telegram",
          "href": "https://t.me/UniPaymentss"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Try Unipay",
      "href": "https://unipayfi.pro"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/UniPaymentss",
      "github": "https://github.com/unipayy/solana-privacy-layer",
      "website": "https://unipayfi.pro"
    }
  }
}