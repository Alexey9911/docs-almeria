{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Unipay",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "appearance": {
    "default": "dark"
  },
  "css": ["styles.css"],
  "theme": "mint",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "quickstart",
              "how-it-works"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/send",
              "features/swap",
              "features/payroll",
              "features/privacy"
            ]
          },
          {
            "group": "About",
            "pages": [
              "about/team",
              "about/roadmap",
              "about/security"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              "legal/terms",
              "legal/conditions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Launch App",
          "icon": "rocket",
          "href": "https://app.unipay.com"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/unipay"
        },
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://discord.gg/unipay"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Security",
        "href": "mailto:security@unipay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.unipay.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/unipay",
      "github": "https://github.com/unipay",
      "discord": "https://discord.gg/unipay"
    }
  }
}